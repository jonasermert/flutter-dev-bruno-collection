meta {
  name: Flutter Development API Toolkit
  type: collection
  version: 1
}

docs {
  # Flutter Development API Toolkit

  Eine Bruno Collection für Flutter-Entwicklung: lokale APIs, Auth-Flows, Firebase Emulatoren, Firestore REST, Storage Uploads, RevenueCat/Webhooks und Debug-Header für Mobile Apps.

  Öffnen: Bruno → Open Collection → diesen Ordner auswählen.
}

vars:pre-request {
  app_version: 1.0.0
  platform: android
  locale: de-DE
}
